{
  "name": "zerowaste-os-backend",
  "version": "1.0.0",
  "description": "ZeroWaste OS - AI-powered food waste reduction platform backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "keywords": [
    "zerowaste",
    "food",
    "sustainability",
    "express",
    "typescript"
  ],
  "author": "ZeroWaste OS Team",
  "license": "MIT",
  "dependencies": {
    "@types/compression": "^1.8.1",
    "axios": "^1.7.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.2",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
